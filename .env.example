# Telegram Bot Configuration
BOT_NAME=your_bot_name
BOT_TOKEN={your-token}}

# Admin secret for database export/import commands (optional)
# If not set, a secret will be generated from bot token (first 16 chars of MD5 hash)
ADMIN_SECRET=

# Database Configuration (for production)
# DB_URL=jdbc:postgresql://localhost:5432/character_bot
# DB_USERNAME=your_username
# DB_PASSWORD=your_password
